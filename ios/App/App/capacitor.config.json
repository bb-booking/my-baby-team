{
	"appId": "dk.meloparents.app",
	"appName": "Melo Parents",
	"webDir": "dist",
	"ios": {
		"contentInset": "never"
	},
	"plugins": {
		"StatusBar": {
			"style": "DEFAULT",
			"overlaysWebView": true,
			"backgroundColor": "#00000000"
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	},
	"packageClassList": [
		"PushNotificationsPlugin",
		"StatusBarPlugin"
	]
}
